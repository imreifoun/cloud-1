
services:
  mysql:
    image: mariadb:10.11  # Smaller than mysql:8.0
    container_name: cloud1_mysql
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD}
      MYSQL_DATABASE: ${MYSQL_DATABASE}
      MYSQL_USER: ${MYSQL_USER}
      MYSQL_PASSWORD: ${MYSQL_PASSWORD}
    volumes:
      - mysql_data:/var/lib/mysql
    networks:
      - cloud1_network
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s

  wordpress:
    image: wordpress:6.4-php8.1-fpm-alpine  # Alpine = smaller
    container_name: cloud1_wordpress
    restart: unless-stopped
    depends_on:
      mysql:
        condition: service_healthy
    environment:
      WORDPRESS_DB_HOST: mysql:3306
      WORDPRESS_DB_NAME: ${MYSQL_DATABASE}
      WORDPRESS_DB_USER: ${MYSQL_USER}
      WORDPRESS_DB_PASSWORD: ${MYSQL_PASSWORD}
      WORDPRESS_TABLE_PREFIX: wp_
      WORDPRESS_DEBUG: 'false'
    volumes:
      - wordpress_data:/var/www/html
    networks:
      - cloud1_network

  phpmyadmin:
    image: phpmyadmin:latest
    container_name: cloud1_phpmyadmin
    restart: unless-stopped
    depends_on:
      - mysql
    environment:
      PMA_HOST: mysql
      PMA_PORT: 3306
      PMA_USER: root
      PMA_PASSWORD: ${MYSQL_ROOT_PASSWORD}
      UPLOAD_LIMIT: 64M
    networks:
      - cloud1_network

  nginx:
    image: nginx:alpine
    container_name: cloud1_nginx
    restart: unless-stopped
    depends_on:
      - wordpress
      - phpmyadmin
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - wordpress_data:/var/www/html:ro
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - ./conf.d:/etc/nginx/conf.d:ro
      - /opt/cloud1/certbot_data:/etc/letsencrypt:ro
      - /opt/cloud1/certbot_www:/var/www/certbot:ro
    networks:
      - cloud1_network

  certbot:
    image: certbot/certbot:latest
    container_name: cloud1_certbot
    volumes:
      - certbot_data:/etc/letsencrypt
      - certbot_www:/var/www/certbot
    entrypoint: "/bin/sh -c 'trap exit TERM; while :; do certbot renew --webroot -w /var/www/certbot --quiet; sleep 12h & wait $${!}; done;'"
    networks:
      - cloud1_network

volumes:
  mysql_data:
    driver: local
  wordpress_data:
    driver: local
  certbot_data:
    driver: local
  certbot_www:
    driver: local

networks:
  cloud1_network:
    driver: bridge
