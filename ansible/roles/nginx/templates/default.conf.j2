upstream wordpress {
    server wordpress:9000;
}

upstream phpmyadmin {
    server phpmyadmin:80;
}

# HTTP - Redirect to HTTPS
server {
    listen 80;
    server_name camagru.dev www.camagru.dev;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$server_name$request_uri;
    }
}

# HTTPS Server
server {
    listen 443 ssl;
    http2 on;
    server_name camagru.dev www.camagru.dev;

    root /var/www/html;
    index index.php index.html;

    ssl_certificate /etc/letsencrypt/live/camagru.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/camagru.dev/privkey.pem;
    
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # phpMyAdmin location (FIRST - highest priority)
    location ^~ /phpmyadmin/ {
        proxy_pass http://phpmyadmin/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 443;
        
        # Important for phpMyAdmin redirects
        proxy_redirect http://$host/phpmyadmin/ https://$host/phpmyadmin/;
        proxy_redirect http://phpmyadmin/ https://$host/phpmyadmin/;
        
        proxy_buffering off;
        proxy_request_buffering off;
    }

    # WordPress (default)
    location / {
        try_files $uri $uri/ /index.php?$args;
    }

    location ~ \.php$ {
        try_files $uri =404;
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass wordpress;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param PATH_INFO $fastcgi_path_info;
        fastcgi_param HTTPS on;
    }

    location ~ /\.ht {
        deny all;
    }
}
